# App Runner runtime environment variables for this application.
# Set secret values in App Runner or AWS Secrets Manager, not in git.

PORT=8080

# Recommended: use a single JDBC URL for Amazon RDS PostgreSQL.
DB_URL=jdbc:postgresql://your-rds-endpoint.ap-northeast-1.rds.amazonaws.com:5432/taskdb
DB_USERNAME=app
DB_PASSWORD=replace-in-aws

APP_SECURITY_USERNAME=appuser
APP_SECURITY_PASSWORD=replace-in-aws
APP_SECURITY_ROLE=ADMIN

JWT_SECRET=replace-with-a-32-byte-or-longer-secret-key
JWT_ACCESS_EXPIRATION=PT15M
JWT_REFRESH_EXPIRATION=P7D

AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW=PT15M
AUTH_RATE_LIMIT_BLOCK_DURATION=PT15M
