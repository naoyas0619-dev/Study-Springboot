# Sample environment variables for local Docker Compose use.
POSTGRES_DB=taskdb
POSTGRES_USER=app
# Change this before running Docker Compose.
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DB_HOST=localhost
DB_PORT=5432
# Optional full JDBC URL for managed databases such as Amazon RDS.
# DB_URL=jdbc:postgresql://your-rds-endpoint:5432/taskdb
API_PORT=8080
# Optional runtime port for cloud platforms. Leave commented for local use.
# PORT=8080
APP_SECURITY_USERNAME=appuser
# Change this before starting the app.
APP_SECURITY_PASSWORD=change-this-password-123
APP_SECURITY_ROLE=ADMIN
# Change this to your own 32-byte-or-longer secret.
JWT_SECRET=replace-with-a-32-byte-or-longer-secret-key
JWT_ACCESS_EXPIRATION=PT15M
JWT_REFRESH_EXPIRATION=P7D
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW=PT15M
AUTH_RATE_LIMIT_BLOCK_DURATION=PT15M
